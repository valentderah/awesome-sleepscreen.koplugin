msgid "Footer template uses % codes from placeholder reference."
msgstr "В подписи к цитате используйте коды с % — см. справку «Коды шаблона виджета»."

msgid "Grid column gap (px, 0 = default gap)"
msgstr "Зазор между столбцами сетки (px, 0 = общий зазор)"

msgid "Grid horizontal inset (px)"
msgstr "Горизонтальный отступ сетки (px)"

msgid "Grid horizontal inset from screen (px)"
msgstr "Горизонтальный отступ сетки от краёв экрана (px)"

msgid "Grid row gap (px, 0 = default gap)"
msgstr "Зазор между строками сетки (px, 0 = общий зазор)"

