msgstr "编辑…"

msgid "Footer template uses % codes from placeholder reference."
msgstr "脚注模板请使用 % 代码 — 详见「模板小组件代码」说明。"

msgid "Grid column gap (px, 0 = default gap)"
msgstr "网格列间距（像素，0 表示使用默认）"

msgid "Grid horizontal inset (px)"
msgstr "网格横向边距（像素）"

msgid "Grid horizontal inset from screen (px)"
msgstr "网格距屏幕左右留白（像素）"

msgid "Grid row gap (px, 0 = default gap)"
msgstr "网格行间距（像素，0 表示使用默认）"

msgid "Grid vertical inset (px)"
msgstr "网格纵向边距（像素）"

msgid "Grid vertical inset from screen (px)"
msgstr "网格距屏幕上/下留白（像素）"

msgid "Highlight uses document annotations (see KOReader docs)."
msgstr "摘录来自文档批注（参见 KOReader 文档）。"

msgid "Left/right margin between the screen border and the 6×3 grid; scaled for DPI. When unset, the combined \"legacy\" inset value is used for this axis."
msgstr "屏幕左右边与 6×3 网格之间的边距；按 DPI 缩放。若未单独设置该轴，则使用合并后的旧版单边距值。"

msgid "MIN"
msgstr "分钟"

msgid "No book open"
msgstr "未打开书籍"

msgid "No book selected"
msgstr "未选择书籍"

msgid "No quotes of the selected highlight types"
msgstr "没有符合所选突出显示类型的摘录"

msgid "No quotes saved for this book yet"
msgstr "本书尚无已保存的摘录"

msgid "Not enough space for this widget here."
msgstr "此处空间不足以放置该小组件。"

msgid "Random highlight"
msgstr "随机摘录"

msgid "READING · TODAY"
msgstr "今日阅读 ·"

msgid "Reading time today"
msgstr "今日阅读时长"

msgid "Remove widget"
msgstr "移除小组件"

msgid "Row %d (%s)"
msgstr "第 %d 行（%s）"

msgid "Row %d, column %d — (wider widget @ %d,%d)"
msgstr "第 %d 行，第 %d 列 —（较宽小组件位于 %d,%d）"

msgid "Row %d, column %d — %s"
msgstr "第 %d 行，第 %d 列 — %s"

msgid "Row %d, column %d — %s (%d cols)"
msgstr "第 %d 行，第 %d 列 — %s（%d 列）"

msgid "Row %d, column %d — empty"
msgstr "第 %d 行，第 %d 列 — 空"

msgid "Save"
msgstr "保存"

msgid "Settings"
msgstr "设置"

msgid "Sleep banner refresh interval (seconds, 0 = off)"
msgstr "睡眠横幅刷新间隔（秒，0 为关闭）"

msgid "Sleepscreen widgets"
msgstr "睡眠屏幕小组件"

msgid "strftime format"
msgstr "strftime 格式"

msgid "Template"
msgstr "模板"

msgid "Template widget codes"
msgstr "模板小组件代码"

msgid "Text template"
msgstr "文本模板"

msgid "That width does not fit here."
msgstr "该宽度在此处放不下。"

msgid "This cell is part of a widget anchored at row %d, column %d."
msgstr "此格子属于锚定在第 %d 行、第 %d 列的小组件。"

msgid "Title & stats lines use the same codes as the KOReader sleep screen message editor:\n\n"
msgstr "标题与进度行使用与 KOReader「睡眠屏幕消息」编辑器相同的代码：\n\n"

msgid "Top/bottom margin between the screen border and the 6×3 grid; scaled for DPI. When unset, the combined \"legacy\" inset value is used for this axis."
msgstr "屏幕上/下边缘与 6×3 网格之间的边距；按 DPI 缩放。若未单独设置该轴，则使用合并后的旧版单边距值。"

msgid "Untitled"
msgstr "无标题"

msgid "Default after plugin update is 10 minutes (600 s). Use 0 to turn auto-refresh off. When greater than zero, dynamic widgets (clock, date, battery, calendar, analog clock) refresh periodically. Values below 60 seconds (1 minute) are clamped to 60 seconds. Large intervals save battery."
msgstr "插件更新后默认为 10 分钟（600 秒）。填 0 可关闭自动刷新。大于零时，时钟、日期、电量、日历与指针表会定时刷新；低于 60 秒（1 分钟）的值会被限制为 60 秒。间隔越大越省电。"

msgid "When ON, replaces the sleep-screen banner with the 6×3 grid layout when KOReader uses Banner message mode."
msgstr "开启后，当 KOReader 使用 Banner 消息模式时，用 6×3 网格布局替换睡眠横幅。"

msgid "Widget corner radius"
msgstr "小组件圆角"

msgid "Widget corner radius (px)"
msgstr "小组件圆角（像素）"

msgid "Widget padding"
msgstr "小组件内边距"

msgid "Widget padding (px)"
msgstr "小组件内边距（像素）"

msgid "Widget width: 1 column"
msgstr "小组件宽度：1 列"

msgid "Widget width: 2 columns"
msgstr "小组件宽度：2 列"

msgid "Widget width: 3 columns"
msgstr "小组件宽度：3 列"

msgid "Widgets grid (6×3)"
msgstr "小组件网格（6×3）"

msgid "Column gap"
msgstr "列间距"

msgid "Row gap"
msgstr "行间距"

msgid "\n\n\nQuote footer (under the highlight) uses doubled percents so it does not clash with KOReader codes:\n\n"
msgstr "\n\n\n摘录脚注使用双百分号，以免与 KOReader 的消息占位符冲突：\n\n"

msgid "%T title\n%A author\n%S series\n%t total pages\n%c current page\n%l pages left in chapter\n%p book percentage read\n%H time left in book\n%C chapter title\n%P chapter percentage read\n%h time left in chapter\n%F file path\n%f file name\n%b battery level\n%B battery symbol\n%r separator (reader footer separator)\n%D current date (yyyy-mm-dd)\n%d current date (mm-dd)\n%m current time (hh:mm)\n%M current time (hh:mm:ss)\n"
msgstr "%T title\n%A author\n%S series\n%t total pages\n%c current page\n%l pages left in chapter\n%p book percentage read\n%H time left in book\n%C chapter title\n%P chapter percentage read\n%h time left in chapter\n%F file path\n%f file name\n%b battery level\n%B battery symbol\n%r separator (reader footer separator)\n%D current date (yyyy-mm-dd)\n%d current date (mm-dd)\n%m current time (hh:mm)\n%M current time (hh:mm:ss)\n"

msgid "%%DT date of highlight (short)\n%%HM time of highlight (hh:mm)\n%%PG page / page label of highlight\n%%C chapter of highlight\n%%A author (document metadata)\n%%T title (document metadata)\n\nUse \\n in templates for a line break.\n"
msgstr "%%DT date of highlight (short)\n%%HM time of highlight (hh:mm)\n%%PG page / page label of highlight\n%%C chapter of highlight\n%%A author (document metadata)\n%%T title (document metadata)\n\nUse \\n in templates for a line break.\n"
