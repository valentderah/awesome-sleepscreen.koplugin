msgid "Daily goal (statistics minutes)…"
msgstr "每日目标（统计分钟数）…"

msgid "Date & time header"
msgstr "日期与时间"

msgid "Default gap"
msgstr "默认间距"

msgid "Default grid / widget gap (px)"
msgstr "默认网格/小组件间距（像素）"

msgid "Dial diameter"
msgstr "表盘直径（%）"

msgid "Edit template pattern…"
msgstr "编辑模板正文…"

msgid "Edit time format…"
msgstr "编辑时间格式…"

